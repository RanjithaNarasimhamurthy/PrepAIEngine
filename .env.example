# ─── Reddit API ───────────────────────────────────────────────────────────────
# Create a Reddit app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=PrepAIEngine/1.0 by your_reddit_username

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://prepai:prepai_password@localhost:5432/prepai

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── LLM — Groq (cloud, faster) or Ollama (local fallback) ───────────────────
# Get a free Groq API key at https://console.groq.com
# If GROQ_API_KEY is set, Groq is used. Otherwise Ollama is used automatically.
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# Ollama (used when GROQ_API_KEY is not set)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── FAISS ────────────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=./data/faiss_index.bin
FAISS_METADATA_PATH=./data/faiss_metadata.json

# ─── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_random_32_char_string
DEBUG=false
SESSION_TTL_SECONDS=86400
CACHE_TTL_SECONDS=300
LLM_CACHE_TTL_SECONDS=3600
